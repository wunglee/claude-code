# Claude Code 环境配置
# 复制此文件为 .env 并填入您的实际值

# ═══════════════════════════════════════════════════════════════
# 核心认证（必需）
# ═══════════════════════════════════════════════════════════════

# Anthropic API 密钥 - 主要认证方式
# 获取地址: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ═══════════════════════════════════════════════════════════════
# API 配置（可选）
# ═══════════════════════════════════════════════════════════════

# 自定义 API 端点（默认: https://api.anthropic.com）
ANTHROPIC_BASE_URL=

# 覆盖默认模型（默认: claude-sonnet-4-20250514）
ANTHROPIC_MODEL=

# 快速/便宜操作的小模型
ANTHROPIC_SMALL_FAST_MODEL=

# 自定义请求头（JSON 格式）
ANTHROPIC_CUSTOM_HEADERS={}

# API 超时（毫秒，默认: 600000 = 10分钟）
API_TIMEOUT_MS=600000

# ═══════════════════════════════════════════════════════════════
# 特性开关（对应 src/shims/bun-bundle.ts）
# ═══════════════════════════════════════════════════════════════

# 主动 Agent 模式（自主操作）
CLAUDE_CODE_PROACTIVE=false

# IDE 桥接集成
CLAUDE_CODE_BRIDGE_MODE=false

# 多 Agent 协调器
CLAUDE_CODE_COORDINATOR_MODE=false

# 语音输入/输出
CLAUDE_CODE_VOICE_MODE=false

# 触发式 Agent 操作
CLAUDE_CODE_AGENT_TRIGGERS=false

# 后台会话
CLAUDE_CODE_BG_SESSIONS=false

# 调试模式
CLAUDE_CODE_DEBUG=false

# ═══════════════════════════════════════════════════════════════
# 调试配置
# ═══════════════════════════════════════════════════════════════

# 调试日志级别: debug, info, warn, error
CLAUDE_CODE_DEBUG_LOG_LEVEL=info

# 输出调试信息到 stderr
CLAUDE_CODE_DEBUG_TO_STDERR=false

# 调试日志文件路径
CLAUDE_CODE_DEBUG_FILE=

# ═══════════════════════════════════════════════════════════════
# AWS Bedrock（可选，替代直接 API）
# ═══════════════════════════════════════════════════════════════

# 启用 AWS Bedrock
CLAUDE_CODE_USE_BEDROCK=false

# AWS 区域
CLAUDE_CODE_BEDROCK_AWS_REGION=us-east-1

# AWS 访问密钥
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# 跳过 Bedrock 认证（用于测试）
CLAUDE_CODE_SKIP_BEDROCK_AUTH=false

# ═══════════════════════════════════════════════════════════════
# Google Vertex AI（可选，替代直接 API）
# ═══════════════════════════════════════════════════════════════

# 启用 Vertex AI
CLAUDE_CODE_USE_VERTEX=false

# GCP 项目 ID
ANTHROPIC_VERTEX_PROJECT_ID=

# 跳过 Vertex 认证（用于测试）
CLAUDE_CODE_SKIP_VERTEX_AUTH=false

# ═══════════════════════════════════════════════════════════════
# Azure Foundry（可选，替代直接 API）
# ═══════════════════════════════════════════════════════════════

# 启用 Azure Foundry
CLAUDE_CODE_USE_FOUNDRY=false

# Azure Foundry API 密钥
ANTHROPIC_FOUNDRY_API_KEY=

# 跳过 Foundry 认证（用于测试）
CLAUDE_CODE_SKIP_FOUNDRY_AUTH=false

# ═══════════════════════════════════════════════════════════════
# 运行模式
# ═══════════════════════════════════════════════════════════════

# 简化模式: 跳过 hooks, LSP, 插件同步等
CLAUDE_CODE_SIMPLE=false

# 远程模式
CLAUDE_CODE_REMOTE=false

# 容器 ID
CLAUDE_CODE_CONTAINER_ID=

# 裸模式: 最小化启动（仅使用 ANTHROPIC_API_KEY）
CLAUDE_CODE_BARE=false

# ═══════════════════════════════════════════════════════════════
# 其他
# ═══════════════════════════════════════════════════════════════

# Node.js 选项（如内存限制）
NODE_OPTIONS=

# Corepack 自动固定禁用
COREPACK_ENABLE_AUTO_PIN=0
